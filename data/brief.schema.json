{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Domino Watch Daily Brief",
  "type": "object",
  "required": [
    "date",
    "generated_at",
    "regime_flag",
    "regime_justification",
    "domino_stage",
    "grades",
    "bottom_line",
    "stack",
    "trigger_map",
    "narrative",
    "horizon_rationale",
    "watch_list",
    "sources"
  ],
  "properties": {
    "date": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "generated_at": {
      "type": "string",
      "description": "ISO-8601 timestamp with timezone offset"
    },
    "regime_flag": {
      "type": "string",
      "enum": ["green", "yellow", "red"]
    },
    "regime_justification": { "type": "string", "minLength": 1 },
    "domino_stage": {
      "type": "object",
      "required": ["stage", "label", "justification"],
      "properties": {
        "stage": { "type": "integer", "minimum": 0, "maximum": 5 },
        "label": { "type": "string", "minLength": 1 },
        "justification": { "type": "string", "minLength": 1 }
      }
    },
    "grades": {
      "type": "object",
      "required": ["1w", "2w", "3w", "4w"],
      "additionalProperties": false,
      "properties": {
        "1w": { "$ref": "#/$defs/gradeEntry" },
        "2w": { "$ref": "#/$defs/gradeEntry" },
        "3w": { "$ref": "#/$defs/gradeEntry" },
        "4w": { "$ref": "#/$defs/gradeEntry" }
      }
    },
    "bottom_line": { "type": "string", "minLength": 1 },
    "stack": {
      "type": "array",
      "minItems": 6,
      "maxItems": 12,
      "items": {
        "type": "object",
        "required": ["marker", "level", "change_1d", "note"],
        "properties": {
          "marker": { "type": "string" },
          "level": { "type": ["string", "number", "null"] },
          "change_1d": { "type": ["string", "number", "null"] },
          "note": { "type": "string" }
        }
      }
    },
    "trigger_map": {
      "type": "array",
      "minItems": 1,
      "maxItems": 6,
      "items": {
        "type": "object",
        "required": ["trigger", "status", "note"],
        "properties": {
          "trigger": { "type": "string", "minLength": 1 },
          "status": {
            "type": "string",
            "enum": ["latent", "armed", "cocked", "firing"]
          },
          "note": { "type": "string" }
        }
      }
    },
    "narrative": {
      "type": "object",
      "required": ["p1", "p2", "p3"],
      "properties": {
        "p1": { "type": "string", "minLength": 1 },
        "p2": { "type": "string", "minLength": 1 },
        "p3": { "type": "string", "minLength": 1 }
      }
    },
    "horizon_rationale": {
      "type": "object",
      "required": ["w1_w2", "w2_w3", "w3_w4"],
      "properties": {
        "w1_w2": { "type": "string" },
        "w2_w3": { "type": "string" },
        "w3_w4": { "type": "string" }
      }
    },
    "watch_list": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["title", "url"],
        "properties": {
          "title": { "type": "string" },
          "url": { "type": "string", "format": "uri" }
        }
      }
    }
  },
  "$defs": {
    "gradeEntry": {
      "type": "object",
      "required": ["grade", "label", "driver"],
      "properties": {
        "grade": { "type": "string", "enum": ["A", "B", "C", "D", "F"] },
        "label": { "type": "string" },
        "driver": { "type": "string" }
      }
    }
  }
}
